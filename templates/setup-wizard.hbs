{{!--
  templates/setup-wizard.hbs
  First-run setup wizard body + footer. Rendered inside the AppV2 <form>.
  All copy is passed pre-localized via _prepareContext (labels.*) — this
  template carries no literal user-visible strings.

  Linear flow: exactly one is* flag is true per render, selecting the step
  body. Navigation buttons are type="button" + data-action so they never
  submit the form (which would fire the merge handler but not navigate).

  Later steps flesh out the dependency, table-user, settings, and connectivity
  bodies; the framework (header, per-step switch, footer) is stable.
--}}
<div class="community-screen-setup-wizard-body">
  <p class="community-screen-setup-wizard-progress">{{labels.progress}}</p>

  {{#if isWelcome}}
  <section class="community-screen-setup-wizard-step">
    <h2 class="community-screen-setup-wizard-step-title">{{labels.welcomeTitle}}</h2>
    <p class="community-screen-setup-wizard-lede">{{labels.welcomeBody}}</p>
  </section>
  {{/if}}

  {{#if isDependencies}}
  <section class="community-screen-setup-wizard-step">
    <h2 class="community-screen-setup-wizard-step-title">{{labels.dependenciesTitle}}</h2>
    <p class="community-screen-setup-wizard-lede">{{labels.dependenciesBody}}</p>
    <ul class="community-screen-setup-wizard-deps">
      {{#each dependencies}}
      <li class="community-screen-setup-wizard-dep {{#if this.active}}is-active{{else}}is-inactive{{/if}}">
        <i class="fa-solid {{#if this.active}}fa-circle-check{{else}}fa-circle-xmark{{/if}}"></i>
        <span class="community-screen-setup-wizard-dep-name">{{this.id}}</span>
        <span class="community-screen-setup-wizard-dep-status">{{this.statusText}}</span>
      </li>
      {{/each}}
    </ul>
    {{#unless depsOk}}
    <p class="community-screen-setup-wizard-warn">{{labels.dependenciesInstruction}}</p>
    {{/unless}}
  </section>
  {{/if}}

  {{#if isTableUser}}
  <section class="community-screen-setup-wizard-step">
    <h2 class="community-screen-setup-wizard-step-title">{{labels.tableUserTitle}}</h2>
    <p class="community-screen-setup-wizard-lede">{{labels.tableUserBody}}</p>

    {{#if showReuseOffer}}
    <div class="community-screen-setup-wizard-reuse">
      <p>{{labels.tableUserReuse}}</p>
      <button type="button" data-action="reuse-table-user">
        <i class="fa-solid fa-rotate-left"></i>
        <span>{{labels.tableUserReuseAction}}</span>
      </button>
    </div>
    {{/if}}

    <div class="community-screen-setup-wizard-field">
      <label class="community-screen-setup-wizard-choice">
        <input type="radio" name="tableUserMode" value="create" {{#if tableUserModeCreate}}checked{{/if}} />
        <span>{{labels.modeCreate}}</span>
      </label>
      <label class="community-screen-setup-wizard-choice">
        <input type="radio" name="tableUserMode" value="select" {{#if tableUserModeSelect}}checked{{/if}} />
        <span>{{labels.modeSelect}}</span>
      </label>
    </div>

    {{!-- Both sub-blocks are always in the DOM; _bindTableUserReveal toggles
          .is-hidden on the mode radio so the switch needs no re-render. --}}
    <div class="community-screen-setup-wizard-mode-block {{#unless tableUserModeCreate}}is-hidden{{/unless}}" data-mode-block="create">
      <p class="community-screen-setup-wizard-hint">{{labels.tableUserCreateHint}}</p>
    </div>

    <div class="community-screen-setup-wizard-mode-block {{#unless tableUserModeSelect}}is-hidden{{/unless}}" data-mode-block="select">
      {{#if hasUserOptions}}
      <div class="community-screen-setup-wizard-field">
        <label class="community-screen-setup-wizard-field-label" for="community-screen-setup-wizard-user-select">{{labels.tableUserSelectLabel}}</label>
        <select id="community-screen-setup-wizard-user-select" name="tableUserId">
          {{#each userOptions}}
          <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
          {{/each}}
        </select>
      </div>
      {{else}}
      <p class="community-screen-setup-wizard-warn">{{labels.tableUserEmpty}}</p>
      {{/if}}
    </div>
  </section>
  {{/if}}

  {{#if isSettings}}
  <section class="community-screen-setup-wizard-step">
    <h2 class="community-screen-setup-wizard-step-title">{{labels.settingsTitle}}</h2>
    <p class="community-screen-setup-wizard-lede">{{labels.settingsBody}}</p>
  </section>
  {{/if}}

  {{#if isConnectivity}}
  <section class="community-screen-setup-wizard-step">
    <h2 class="community-screen-setup-wizard-step-title">{{labels.connectivityTitle}}</h2>
    <p class="community-screen-setup-wizard-lede">{{labels.connectivityBody}}</p>
  </section>
  {{/if}}
</div>

<footer class="community-screen-setup-wizard-footer">
  <button type="button" class="community-screen-setup-wizard-dismiss" data-action="dismiss">
    {{labels.dismiss}}
  </button>
  <span class="community-screen-setup-wizard-footer-spacer"></span>
  <button type="button" data-action="back" {{#unless canBack}}disabled{{/unless}}>
    <i class="fa-solid fa-arrow-left"></i>
    <span>{{labels.back}}</span>
  </button>
  {{#if isLast}}
  <button type="button" class="community-screen-setup-wizard-primary" data-action="finish">
    <i class="fa-solid fa-check"></i>
    <span>{{labels.finish}}</span>
  </button>
  {{else}}
  <button type="button" class="community-screen-setup-wizard-primary" data-action="next">
    <span>{{labels.next}}</span>
    <i class="fa-solid fa-arrow-right"></i>
  </button>
  {{/if}}
</footer>
